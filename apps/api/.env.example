NODE_ENV=development
PORT=3000

# PostgreSQL — use pooler URL for app, direct URL for migrations
DATABASE_URL="postgresql://user:pass@host:6543/db?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (minimum 32 chars each)
JWT_ACCESS_SECRET="replace_me_with_a_long_random_string_min_32chars"
JWT_REFRESH_SECRET="replace_me_with_another_long_random_string_32chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# S3 / Cloudflare R2
S3_BUCKET="dharti-store"
S3_REGION="auto"
S3_ACCESS_KEY="your_access_key"
S3_SECRET_KEY="your_secret_key"
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"

# Email (Resend)
RESEND_API_KEY="re_xxx"
FROM_EMAIL="noreply@dhartistore.in"

# App
APP_URL="http://localhost:3001"

# Platform GST identity (for invoice generation)
PLATFORM_GSTIN="22AAAAA0000A1Z5"
PLATFORM_LEGAL_NAME="Dharti Store Pvt Ltd"
PLATFORM_ADDRESS="123, Main Street, Bengaluru - 560001"
PLATFORM_STATE="Karnataka"

# Seed defaults (optional — override in CI)
SUPER_ADMIN_EMAIL="admin@dhartistore.in"
SUPER_ADMIN_PASSWORD="Admin@1234!"
