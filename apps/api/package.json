{
  "name": "@marketplace/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo \"add lint config\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate deploy --config prisma.config.mjs",
    "db:studio": "prisma studio --config prisma.config.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@nestjs/common": "^10",
    "@nestjs/core": "^10",
    "@nestjs/platform-express": "^10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2",
    "bullmq": "^5",
    "date-fns": "^3",
    "decimal.js": "^10",
    "dotenv": "^16",
    "ioredis": "^5",
    "jsonwebtoken": "^9",
    "nanoid": "^3",
    "pg": "^8.21.0",
    "pino": "^9",
    "pino-http": "^10",
    "razorpay": "^2",
    "reflect-metadata": "^0.1.13",
    "resend": "^3",
    "rxjs": "^7",
    "slugify": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "@types/express": "^4",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^20",
    "pino-pretty": "^13.1.3",
    "prisma": "^7",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^1"
  }
}
